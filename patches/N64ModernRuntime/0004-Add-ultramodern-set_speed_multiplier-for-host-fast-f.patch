From 3038cb465fa4bd22972b3287694f0359b3359282 Mon Sep 17 00:00:00 2001
From: Thiago Lira <thlira15@gmail.com>
Date: Thu, 9 Jul 2026 11:54:22 -0300
Subject: [PATCH] Add ultramodern::set_speed_multiplier for host fast-forward

Makes the game-speed multiplier a runtime atomic (was constexpr 1); the VI
thread and the CPU counter rate both follow it. 0 clamps to 1.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_016g6NrpY7bmbqNfAxa23cTC
---
 .../include/ultramodern/ultramodern.hpp       |  1 +
 ultramodern/src/timer.cpp                     | 19 +++++++++++++------
 2 files changed, 14 insertions(+), 6 deletions(-)

diff --git a/ultramodern/include/ultramodern/ultramodern.hpp b/ultramodern/include/ultramodern/ultramodern.hpp
index 46aea61..816f366 100644
--- a/ultramodern/include/ultramodern/ultramodern.hpp
+++ b/ultramodern/include/ultramodern/ultramodern.hpp
@@ -102,6 +102,7 @@ bool is_game_thread();
 void submit_rsp_task(RDRAM_ARG PTR(OSTask) task);
 void send_si_message();
 uint32_t get_speed_multiplier();
+void set_speed_multiplier(uint32_t multiplier); // 0 clamps to 1
 
 // Time
 std::chrono::high_resolution_clock::time_point get_start();
diff --git a/ultramodern/src/timer.cpp b/ultramodern/src/timer.cpp
index ee26c45..48c215d 100644
--- a/ultramodern/src/timer.cpp
+++ b/ultramodern/src/timer.cpp
@@ -1,3 +1,4 @@
+#include <atomic>
 #include <thread>
 #include <variant>
 #include <set>
@@ -15,10 +16,12 @@
 static std::chrono::high_resolution_clock::time_point start_time = std::chrono::high_resolution_clock::now();
 // Offset of the duration since program start used to calculate the value for osGetTime. 
 static int64_t ostime_offset = 0;
-// Game speed multiplier (1 means no speedup)
-constexpr uint32_t speed_multiplier = 1;
+// Game speed multiplier (1 means no speedup). Runtime-adjustable so hosts
+// can offer fast-forward; the VI thread re-reads it every tick and the
+// counter rate below follows it.
+static std::atomic<uint32_t> speed_multiplier{1};
 // N64 CPU counter ticks per millisecond
-constexpr uint32_t counter_per_ms = 46'875 * speed_multiplier;
+static uint32_t counter_per_ms() { return 46'875 * speed_multiplier.load(std::memory_order_relaxed); }
 
 struct OSTimer {
     PTR(OSTimer) unused1;
@@ -48,14 +51,14 @@ uint64_t duration_to_ticks(std::chrono::high_resolution_clock::duration duration
     uint64_t delta_micros = std::chrono::duration_cast<std::chrono::microseconds>(duration).count();
     // More accurate than using a floating point timer, will only overflow after running for 12.47 years
     // Units: (micros * (counts/millis)) / (micros/millis) = counts
-    uint64_t total_count = (delta_micros * counter_per_ms) / 1000;
+    uint64_t total_count = (delta_micros * counter_per_ms()) / 1000;
 
     return total_count;
 }
 
 std::chrono::microseconds ticks_to_duration(uint64_t ticks) {
     using namespace std::chrono_literals;
-    return ticks * 1000us / counter_per_ms;
+    return ticks * 1000us / counter_per_ms();
 }
 
 std::chrono::high_resolution_clock::time_point ticks_to_timepoint(uint64_t ticks) {
@@ -146,7 +149,11 @@ void ultramodern::init_timers(RDRAM_ARG1) {
 }
 
 uint32_t ultramodern::get_speed_multiplier() {
-    return speed_multiplier;
+    return speed_multiplier.load(std::memory_order_relaxed);
+}
+
+void ultramodern::set_speed_multiplier(uint32_t multiplier) {
+    speed_multiplier.store(multiplier == 0 ? 1 : multiplier, std::memory_order_relaxed);
 }
 
 std::chrono::high_resolution_clock::time_point ultramodern::get_start() {
-- 
2.54.0

