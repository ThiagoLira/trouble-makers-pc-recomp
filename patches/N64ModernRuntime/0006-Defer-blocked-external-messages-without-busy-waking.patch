From 9ed67059a586b6e85006540642b9483e75d3cf23 Mon Sep 17 00:00:00 2001
From: Thiago Lira <thlira15@gmail.com>
Date: Mon, 20 Jul 2026 22:00:00 -0300
Subject: [PATCH] Defer blocked external messages without busy waking

The starvation workaround drains every concurrent-queue producer after a
blocking wait. If an event could not enter a full N64 message queue, however,
it was re-enqueued into that same host wake queue. The idle game thread then
immediately consumed and re-enqueued the undeliverable event forever.

Keep blocked deliveries in a game-thread-owned deferred list instead. Retry
them on fresh host events, game message-API entry, and immediately after a
receive opens queue space. The full producer drain remains intact, preserving
delivery of DP messages that wait_dequeue alone could starve.

An optimized gprofng capture attributed 90.6% of sampled CPU to the old loop.
After this change, a rendered Wayland/NVIDIA capture advanced more than 740
display lists and the drain used 0.001 CPU-second over an eight-second sample.
---
 ultramodern/src/mesgqueue.cpp | 60 +++++++++++++++++++++++++++++++------------
 1 file changed, 44 insertions(+), 16 deletions(-)

diff --git a/ultramodern/src/mesgqueue.cpp b/ultramodern/src/mesgqueue.cpp
index 72069da..ae57146 100644
--- a/ultramodern/src/mesgqueue.cpp
+++ b/ultramodern/src/mesgqueue.cpp
@@ -1,5 +1,6 @@
 #include <bitset>
 #include <thread>
+#include <vector>
 
 #include "blockingconcurrentqueue.h"
 
@@ -14,6 +15,12 @@ struct QueuedMessage {
 };
 
 static moodycamel::BlockingConcurrentQueue<QueuedMessage> external_messages {};
+// Messages whose destination N64 queue was full must be retried, but putting
+// them back in external_messages turns them into wake events. An idle game
+// thread then consumes and re-enqueues the same undeliverable message forever.
+// Only one emulated game thread runs at a time, so this list is game-thread
+// owned and does not need to contend with the host producer threads.
+static std::vector<QueuedMessage> deferred_messages {};
 std::bitset<32> requeue_enabled;
 
 void ultramodern::set_message_queue_control(const ultramodern::MessageQueueControl& mqc) {
@@ -39,30 +46,42 @@ bool do_send(RDRAM_ARG PTR(OSMesgQueue) mq_, OSMesg msg, bool jam, bool block);
 
 static bool mm_q_trace(uint32_t mq); // TEMP (trouble-makers bring-up), defined below
 
+static bool try_deliver_external_message(RDRAM_ARG const QueuedMessage& to_send, const char* path) {
+    if (mm_q_trace((uint32_t)to_send.mq)) {
+        fprintf(stderr, "[ev] deq   mq %08X (%s)\n", (uint32_t)to_send.mq, path);
+    }
+    return do_send(PASS_RDRAM to_send.mq, to_send.mesg, to_send.jam, false) ||
+        !to_send.requeue_if_blocked;
+}
+
 void dequeue_external_messages(RDRAM_ARG1) {
+    // Retry older blocked deliveries without making them wake sources. Compact
+    // in place so the normal 60 Hz retry path stops allocating after warm-up.
+    size_t still_deferred = 0;
+    const size_t retry_count = deferred_messages.size();
+    for (size_t i = 0; i < retry_count; ++i) {
+        const QueuedMessage to_send = deferred_messages[i];
+        if (!try_deliver_external_message(PASS_RDRAM to_send, "deferred")) {
+            deferred_messages[still_deferred++] = to_send;
+        }
+    }
+    deferred_messages.resize(still_deferred);
+
+    // A full drain is still required: try_dequeue visits the independent
+    // producer streams that wait_dequeue alone can starve.
     QueuedMessage to_send;
-    std::vector<QueuedMessage> requeued_messages{};
     while (external_messages.try_dequeue(to_send)) {
-        if (mm_q_trace((uint32_t)to_send.mq)) {
-            fprintf(stderr, "[ev] deq   mq %08X (drain)\n", (uint32_t)to_send.mq);
-        }
-        if (!do_send(PASS_RDRAM to_send.mq, to_send.mesg, to_send.jam, false) && to_send.requeue_if_blocked) {
-            requeued_messages.push_back(to_send);
+        if (!try_deliver_external_message(PASS_RDRAM to_send, "drain")) {
+            deferred_messages.push_back(to_send);
         }
     }
-    for (QueuedMessage& cur_mesg : requeued_messages) {
-        external_messages.enqueue(cur_mesg);
-    }
 }
 
 void ultramodern::wait_for_external_message(RDRAM_ARG1) {
     QueuedMessage to_send;
     external_messages.wait_dequeue(to_send);
-    if (mm_q_trace((uint32_t)to_send.mq)) {
-        fprintf(stderr, "[ev] deq   mq %08X (wait)\n", (uint32_t)to_send.mq);
-    }
-    if (!do_send(PASS_RDRAM to_send.mq, to_send.mesg, to_send.jam, false) && to_send.requeue_if_blocked) {
-        external_messages.enqueue(to_send);
+    if (!try_deliver_external_message(PASS_RDRAM to_send, "wait")) {
+        deferred_messages.push_back(to_send);
     }
     // Deliver everything else that's pending, not just the first message.
     // A single wait_dequeue can starve items that sit in another producer
@@ -77,8 +96,11 @@ void ultramodern::wait_for_external_message(RDRAM_ARG1) {
 void ultramodern::wait_for_external_message_timed(RDRAM_ARG u32 millis) {
     QueuedMessage to_send;
     if (external_messages.wait_dequeue_timed(to_send, std::chrono::milliseconds{millis})) {
-        if (!do_send(PASS_RDRAM to_send.mq, to_send.mesg, to_send.jam, false) && to_send.requeue_if_blocked) {
-            external_messages.enqueue(to_send);
+        if (!try_deliver_external_message(PASS_RDRAM to_send, "timed")) {
+            deferred_messages.push_back(to_send);
         }
+        // A fresh host event is also the retry signal for older blocked
+        // deliveries, matching the non-timed wait path.
+        dequeue_external_messages(PASS_RDRAM1);
     }
 }
@@ -247,6 +269,12 @@ extern "C" s32 osRecvMesg(RDRAM_ARG PTR(OSMesgQueue) mq_, PTR(OSMesg) msg_, s32
 
     // Try to receive a message.
     bool received = do_recv(PASS_RDRAM mq_, msg_, flags == OS_MESG_BLOCK);
+
+    // Receiving may have opened space for an older deferred host event. Retry
+    // it immediately rather than waiting for the next VI or other host wakeup.
+    if (received && !deferred_messages.empty()) {
+        dequeue_external_messages(PASS_RDRAM1);
+    }
     
     // Check the queue to see if this thread should swap execution to another.
     ultramodern::check_running_queue(PASS_RDRAM1);
-- 
