diff --git a/src/render/rt64_vi_renderer.cpp b/src/render/rt64_vi_renderer.cpp
index d597d75..2164d4f 100644
--- a/src/render/rt64_vi_renderer.cpp
+++ b/src/render/rt64_vi_renderer.cpp
@@ -78,6 +78,8 @@ namespace RT64 {
         pushConstants.videoResolution = fbHdRegion;
         pushConstants.textureResolution = { float(p.textureWidth), float(p.textureHeight) };
         pushConstants.gamma = p.vi->gamma();
+        pushConstants.uvScale = { 1.0f, 1.0f };
+        pushConstants.uvOffset = { 0.0f, 0.0f };
 
         p.commandList->setPipeline(shader->pipeline.get());
         p.commandList->setGraphicsPipelineLayout(shader->pipelineLayout.get());
@@ -85,6 +87,60 @@ namespace RT64 {
         p.commandList->setGraphicsPushConstants(0, &pushConstants);
         p.commandList->setVertexBuffers(0, nullptr, 0, nullptr);
         p.commandList->drawInstanced(3, 1, 0, 0);
+
+        // [MM] Optional wing mirror: with a widescreen aspect (Expand), the
+        // game's 2D layers only cover a centered 4:3 band of the image and the
+        // pillarbox "wings" are black. Redraw each wing sampling the image
+        // mirrored around the 4:3 edge — seam-continuous by construction —
+        // and slightly darkened (higher gamma) so the fill reads as ambience
+        // rather than gameplay. Enabled by the host via MM_MIRROR_WINGS=1.
+        static const bool mirrorWings = []() {
+            const char *env = getenv("MM_MIRROR_WINGS");
+            return (env != nullptr) && (env[0] != '0');
+        }();
+        if (mirrorWings && (viewport.width > 1.0f)) {
+            // Where the game's content sits inside the wide image: the 320px
+            // framebuffer maps to a centered 4:3 band, and Mischief Makers
+            // only renders an active area inside it (view half-width 0x90 =
+            // 144 in Camera_UpdateViewBounds), leaving a black overscan
+            // border baked into the image. Measured edges: left at fb x=16,
+            // right at fb x=300 (the game's rightmost columns stay black).
+            const float kActiveLeft = 16.0f / 320.0f;
+            const float kActiveRight = 300.0f / 320.0f;
+            const float imageAspect = viewport.width / viewport.height;
+            const float bandFraction = (4.0f / 3.0f) / imageAspect;
+            if (bandFraction < 0.999f) {
+                const float bandLeft = (1.0f - bandFraction) * 0.5f;
+                // Content edges in viewport-u space (0..1 across the image).
+                const float uLeft = bandLeft + kActiveLeft * bandFraction;
+                const float uRight = bandLeft + kActiveRight * bandFraction;
+
+                interop::VideoInterfaceCB wingConstants = pushConstants;
+                wingConstants.gamma = pushConstants.gamma * 1.4f;
+                wingConstants.uvScale = { -1.0f, 1.0f };
+
+                auto drawWing = [&](int32_t left, int32_t right, float uvOffsetX) {
+                    if (right <= left) {
+                        return;
+                    }
+                    RenderRect wingScissor = scissor;
+                    wingScissor.left = std::max(wingScissor.left, left);
+                    wingScissor.right = std::min(wingScissor.right, right);
+                    if (wingScissor.right <= wingScissor.left) {
+                        return;
+                    }
+                    wingConstants.uvOffset = { uvOffsetX, 0.0f };
+                    p.commandList->setScissors(wingScissor);
+                    p.commandList->setGraphicsPushConstants(0, &wingConstants);
+                    p.commandList->drawInstanced(3, 1, 0, 0);
+                };
+
+                // Each wing mirrors around its content edge (u' = 2*edge - u).
+                drawWing(int32_t(viewport.x), int32_t(viewport.x + uLeft * viewport.width), 2.0f * uLeft);
+                drawWing(int32_t(viewport.x + uRight * viewport.width), int32_t(viewport.x + viewport.width), 2.0f * uRight);
+                p.commandList->setScissors(scissor);
+            }
+        }
     }
 
     void VIRenderer::getViewportAndScissor(const RenderSwapChain *swapChain, const VI &vi, hlslpp::float2 resolutionScale, uint32_t downsamplingScale, RenderViewport &viewport, RenderRect &scissor, hlslpp::float2 &fbHdRegion) {
