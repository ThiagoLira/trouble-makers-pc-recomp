+    namespace {
+        void telemetryUpdateMaximum(std::atomic<uint64_t> &target,
+                                    uint64_t value) {
+            uint64_t current = target.load(std::memory_order_relaxed);
+            while ((current < value) &&
+                   !target.compare_exchange_weak(current, value,
+                       std::memory_order_relaxed,
+                       std::memory_order_relaxed)) {}
+        }
+
+        void telemetryRecordTiming(PresentQueueTimingCounters &timing,
+                                   int64_t microseconds) {
+            const uint64_t safeMicroseconds =
+                static_cast<uint64_t>(std::max<int64_t>(microseconds, 0));
+            timing.count.fetch_add(1, std::memory_order_relaxed);
+            timing.sumMicroseconds.fetch_add(
+                safeMicroseconds, std::memory_order_relaxed);
+            telemetryUpdateMaximum(timing.maximumMicroseconds,
+                                   safeMicroseconds);
+        }
+
+        PresentQueueTimingSnapshot telemetryTakeTiming(
+                PresentQueueTimingCounters &timing) {
+            PresentQueueTimingSnapshot result;
+            result.count = timing.count.exchange(0, std::memory_order_relaxed);
+            result.sumMicroseconds = timing.sumMicroseconds.exchange(
+                0, std::memory_order_relaxed);
+            result.maximumMicroseconds = timing.maximumMicroseconds.exchange(
+                0, std::memory_order_relaxed);
+            return result;
+        }
+
+        void telemetryResetTiming(PresentQueueTimingCounters &timing) {
+            timing.count.store(0, std::memory_order_relaxed);
+            timing.sumMicroseconds.store(0, std::memory_order_relaxed);
+            timing.maximumMicroseconds.store(0, std::memory_order_relaxed);
+        }
+
+        uint64_t telemetryPercentile(
+                const std::array<uint64_t,
+                    PresentQueueTelemetryCounters::IntervalHistogramBucketCount> &histogram,
+                uint64_t count, uint64_t percentile) {
+            if (count == 0) {
+                return 0;
+            }
+
+            const uint64_t wanted = (count * percentile + 99) / 100;
+            uint64_t cumulative = 0;
+            for (size_t i = 0; i < histogram.size(); i++) {
+                cumulative += histogram[i];
+                if (cumulative >= wanted) {
+                    return (i + 1) *
+                        PresentQueueTelemetryCounters::IntervalHistogramBucketMicroseconds;
+                }
+            }
+
+            return histogram.size() *
+                PresentQueueTelemetryCounters::IntervalHistogramBucketMicroseconds;
+        }
+    }
