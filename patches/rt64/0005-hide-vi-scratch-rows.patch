+    uint32_t VI::fbRowOffset() const {
+        // The number of rows fbAddress() estimated the framebuffer base to be
+        // above VI_ORIGIN. The VI only displays memory starting at VI_ORIGIN;
+        // games can deliberately keep non-visible scratch data (e.g. palettes
+        // copied with the RDP) in the rows above it, so presentation must skip
+        // them or they show up as a garbage strip at the top of the screen.
+        uint8_t siz = fbSiz();
+        if ((siz < G_IM_SIZ_16b) || (width == 0)) {
+            return 0;
+        }
+
+        return (origin - fbAddress()) / (width * (1U << (siz - 1)));
+    }
