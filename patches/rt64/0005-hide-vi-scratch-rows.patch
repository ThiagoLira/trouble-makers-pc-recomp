+        // Skip the framebuffer rows above VI_ORIGIN: the VI never scans them
+        // out, and games keep scratch data there (Mischief Makers copies
+        // palettes into the first framebuffer row with the RDP). The extra
+        // crop rows emulate CRT overscan for scratch that reaches the first
+        // scanned-out rows; shrinking the sampled region keeps the output
+        // anchored at the top instead of shifting the whole picture up.
+        const float sdRowScale = p.resolutionScale.y /
+            float(std::max(p.downsamplingScale, 1U));
+        const float cropRows = float(p.extraTopCropRows);
+        pushConstants.verticalOffset =
+            (float(p.vi->fbRowOffset()) + cropRows) * sdRowScale;
+        pushConstants.videoResolution.y =
+            std::max(float(fbHdRegion.y) - cropRows * sdRowScale, 1.0f);
