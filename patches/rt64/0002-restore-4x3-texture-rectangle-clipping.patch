 namespace RT64 {
     namespace GBI_RDP {
-        static int32_t rectX(State *state, uint32_t value) {
+        static int32_t signedRectX(uint32_t value) {
             // The RDP rectangle fields are 12-bit fixed-point values. MM's
-            // widescreen hooks intentionally submit rectangles left of x=0;
-            // preserve their two's-complement sign while the wing path is on.
-            if (state->ext.enhancementConfig->rect.clearWings && ((value & 0x800U) != 0)) {
+            if ((value & 0x800U) != 0) {
                 return static_cast<int32_t>(value | ~0xFFFU);
             }
 
             return static_cast<int32_t>(value);
         }
 
+        static int32_t clippedRectLeft(State *state, uint32_t value,
+                bool flip, int16_t dsdx, int16_t dtdy,
+                int16_t &uls, int16_t &ult) {
+            const int32_t signedValue = signedRectX(value);
+            if ((signedValue >= 0) || state->ext.enhancementConfig->rect.clearWings) {
+                return signedValue;
+            }
+
+            // The widened MM display lists start partially off-screen tiles at
+            // S=0. Original 4:3 code clamps X to zero and advances the texture
+            // coordinate by the clipped distance. RDP X is quarter-pixel,
+            // while dS/dX and S use 5.10 and 10.5 fixed point respectively.
+            const int32_t clippedQuarters = -signedValue;
+            if (flip) {
+                ult = static_cast<int16_t>(ult +
+                    ((static_cast<int32_t>(dtdy) * clippedQuarters) >> 7));
+            }
+            else {
+                uls = static_cast<int16_t>(uls +
+                    ((static_cast<int32_t>(dsdx) * clippedQuarters) >> 7));
+            }
+
+            return 0;
+        }
+
