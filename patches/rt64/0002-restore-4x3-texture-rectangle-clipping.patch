 namespace RT64 {
     namespace GBI_RDP {
+        static int32_t signedRectX(uint32_t value) {
+            // MM's widened tile hooks encode off-left X coordinates in the
+            // 12-bit quarter-pixel field using two's complement. Keep those
+            // negative rectangles intact so RT64's normal scissor crops the
+            // geometry and texture interpolation together.
+            if ((value & 0x800U) != 0) {
+                return static_cast<int32_t>(value | ~0xFFFU);
+            }
+
+            return static_cast<int32_t>(value);
+        }
+
         void noOp(State *state, DisplayList **dl) {
             // Do nothing.
         }
