         Framebuffer &framebuffer = framebufferVector[framebufferCount - 1];
+        framebuffer.clearWings = p.clearWings;
+        framebuffer.aspectScale = (p.aspectRatioSource > 0.0f) ? (p.aspectRatioTarget / p.aspectRatioSource) : 1.0f;
